#!/usr/bin/env bash

# 设置 brew 镜像，详见 https://mirrors.tuna.tsinghua.edu.cn/help/homebrew/
function set_brew_mirror() {
    pw_d=$(pwd)
    git -C "$(brew --repo)" remote set-url origin https://mirrors.tuna.tsinghua.edu.cn/git/homebrew/brew.git
    git -C "$(brew --repo homebrew/core)" remote set-url origin https://mirrors.tuna.tsinghua.edu.cn/git/homebrew/homebrew-core.git
    git -C "$(brew --repo homebrew/cask)" remote set-url origin https://mirrors.tuna.tsinghua.edu.cn/git/homebrew/homebrew-cask.git
    export HOMEBREW_BOTTLE_DOMAIN=https://mirrors.tuna.tsinghua.edu.cn/homebrew-bottles
    cd "${pw_d}" || return
}
function reset_brew_mirror() {
    pw_d=$(pwd)
    git -C "$(brew --repo)" remote set-url origin https://github.com/Homebrew/brew.git
    git -C "$(brew --repo homebrew/core)" remote set-url origin https://github.com/Homebrew/homebrew-core.git
    git -C "$(brew --repo homebrew/cask)" remote set-url origin https://github.com/Homebrew/homebrew-cask.git
    unset HOMEBREW_BOTTLE_DOMAIN
    cd "${pw_d}" || return
}

# 设置 Composer 镜像，详见 https://developer.aliyun.com/composer
function set_composer_mirror() {
    composer config -g repo.packagist composer https://mirrors.aliyun.com/composer/
}
function reset_composer_mirror() {
    composer config -g --unset repos.packagist
}

# 设置 npm 源，详见 https://npm.taobao.org/
function set_npm_mirror() {
    npm config set registry=https://registry.npm.taobao.org
}
function reset_npm_mirror() {
    npm config delete registry
}

# 设置 yarn 源
function set_yarn_mirror() {
    yarn config set registry https://registry.npm.taobao.org
}
function reset_yarn_mirror() {
    yarn config delete registry
}

# 设置所有可用 mirror
function set_mirror() {
    set_brew_mirror
    set_composer_mirror
    set_npm_mirror
    set_yarn_mirror
}

# 取消设置 mirror
function reset_mirror() {
    reset_brew_mirror
    reset_composer_mirror
    reset_npm_mirror
    reset_yarn_mirror
}

# 设置代理终端命令
function usep() {
    local port=1087
    export ftp_proxy=http://127.0.0.1:${port}
    export http_proxy=http://127.0.0.1:${port}
    export https_proxy=http://127.0.0.1:${port}
}
function unusep() {
    unset ftp_proxy
    unset http_proxy
    unset https_proxy
}

# 更新 brew 包
function updateBrew() {
    brew update
    brew upgrade
    brew cleanup
}

# 更新 vimrc，查看 https://github.com/amix/vimrc
function updateVimrc() {
    cd ~/.vim_runtime || exit
    git checkout .
    git pull --rebase
    if command -v python3 &>/dev/null; then
        python3 update_plugins.py
    else
        python update_plugins.py
    fi
    cd - || exit
}

# 更新其他包 - npm/composer/pip
function update() {
    npm install npm -g
    npm update -g
    composer global update
    if command -v pip3 &>/dev/null && pip3 list --outdated | grep -v '^\-e'; then
        pip3 list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip3 install -U -i https://pypi.tuna.tsinghua.edu.cn/simple
    fi
    if command -v pip &>/dev/null && pip list --outdated | grep -v '^\-e'; then
        pip list --outdated --format=freeze | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip install -U -i https://pypi.tuna.tsinghua.edu.cn/simple
    fi
}

# 创建并进入一个新目录
function mkd() {
    mkdir -p "$@" && cd "$_" || return
}

# 在终端进入 Finder 中打开的文件夹
function cdf() {
    cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')" || return
}

# 解压文件
function extract() {
    if [ -f "$1" ]; then
        case $1 in
        *.tar.bz2) tar xjf "$1" ;;
        *.tar.gz) tar xzf "$1" ;;
        *.bz2) bunzip2 "$1" ;;
        *.rar) unrar e "$1" ;;
        *.gz) gunzip "$1" ;;
        *.tar) tar xf "$1" ;;
        *.tbz2) tar xjf "$1" ;;
        *.tgz) tar xzf "$1" ;;
        *.zip) unzip "$1" ;;
        *.Z) uncompress "$1" ;;
        *.7z) 7z x "$1" ;;
        *) echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# 清理缓存
function cleanCache() {
    yarn cache clean
}

# 移动文件到废纸篓
function trash() {
    command mv "$@" ~/.Trash
}

# 使用 macOS 默认的快速预览打开指定文件
function ql() {
    qlmanage -p "$*" >&/dev/null
}

# 在当前目录根据文件名查找指定文件
function ff() {
    find . -name "$@"
}

# 在当前目录下查找以指定字符串开始的文件
function ffs() {
    echo "$@"'*'
    find . -name "$@"'*'
}

# 在当前目录下查找以指定字符串结尾的文件
function ffe() {
    find . -name '*'"$@"
}

# 创建一个 `.tar.gz` 归档包
function targz() {
    local tmpFile="${@%/}.tar"
    tar -cvf "${tmpFile}" --exclude=".DS_Store" "${@}" || return 1

    size=$(
        stat -f"%z" "${tmpFile}" 2>/dev/null # macOS `stat`
        stat -c"%s" "${tmpFile}" 2>/dev/null # GNU `stat`
    )

    local cmd=""
    if ((size < 52428800)) && hash zopfli 2>/dev/null; then
        # the .tar file is smaller than 50 MB and Zopfli is available; use it
        cmd="zopfli"
    else
        if hash pigz 2>/dev/null; then
            cmd="pigz"
        else
            cmd="gzip"
        fi
    fi

    echo "Compressing .tar ($((size / 1000)) kB) using \`${cmd}\`…"
    "${cmd}" -v "${tmpFile}" || return 1
    [ -f "${tmpFile}" ] && rm "${tmpFile}"

    zippedSize=$(
        stat -f"%z" "${tmpFile}.gz" 2>/dev/null # macOS `stat`
        stat -c"%s" "${tmpFile}.gz" 2>/dev/null # GNU `stat`
    )

    echo "${tmpFile}.gz ($((zippedSize / 1000)) kB) created successfully."
}

# 使用 maven 快速构建一个原型项目
function mvnag() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: mvnag [groupId] [artifactId]"
    else
        mvn archetype:generate \
            -DgroupId="$1" \
            -DartifactId="$2" \
            -DarchetypeGroupId=org.apache.maven.archetypes \
            -DarchetypeArtifactId=maven-archetype-quickstart \
            -DarchetypeVersion=1.4 \
            -DinteractiveMode=false &&
            cd "$2" || return
    fi
}

# 确定文件或目录的大小
function fs() {
    if du -b /dev/null >/dev/null 2>&1; then
        local arg=-sbh
    else
        local arg=-sh
    fi
    if [[ -n "$@" ]]; then
        du $arg -- "$@"
    else
        du $arg .[^.]* ./*
    fi
}

# 使用 git 的 diff 命令来比较两个文件的差异
hash git &>/dev/null
if [ $? -eq 0 ]; then
    function diff() {
        git diff --no-index --color-words "$@"
    }
fi

# 从给定文件创建一个 dataurl
function dataurl() {
    local mimeType=$(file -b --mime-type "$1")
    if [[ $mimeType == text/* ]]; then
        mimeType="${mimeType};charset=utf-8"
    fi
    echo "data:${mimeType};base64,$(openssl base64 -in "$1" | tr -d '\n')"
}

# 创建一个 HTTP Server，通过 npm 的 http-server 包: npm i http-server -g
function server() {
    http-server -p "${1:-8000}" || return
}

# 展示使用 gzip 对文件进行压缩的压缩比
function gz() {
    local origsize=$(wc -c <"$1")
    local gzipsize=$(gzip -c "$1" | wc -c)
    local ratio=$(echo "$gzipsize * 100 / $origsize" | bc -l)
    printf "orig: %d bytes\n" "$origsize"
    printf "gzip: %d bytes (%2.2f%%)\n" "$gzipsize" "$ratio"
}

# 获取所有子域名，例如 getcertnames baidu.com
function getcertnames() {
    if [ -z "${1}" ]; then
        echo "ERROR: No domain specified."
        return 1
    fi

    local domain="${1}"
    echo "Testing ${domain}…"
    echo "" # newline

    local tmp=$(echo -e "GET / HTTP/1.0\nEOT" |
        openssl s_client -connect "${domain}:443" -servername "${domain}" 2>&1)

    if [[ "${tmp}" == *"-----BEGIN CERTIFICATE-----"* ]]; then
        local certText=$(echo "${tmp}" |
            openssl x509 -text -certopt "no_aux, no_header, no_issuer, no_pubkey, \
			no_serial, no_sigdump, no_signame, no_validity, no_version")
        echo "Common Name:"
        echo "" # newline
        echo "${certText}" | grep "Subject:" | sed -e "s/^.*CN=//" | sed -e "s/\/emailAddress=.*//"
        echo "" # newline
        echo "Subject Alternative Name(s):"
        echo "" # newline
        echo "${certText}" | grep -A 1 "Subject Alternative Name:" |
            sed -e "2s/DNS://g" -e "s/ //g" | tr "," "\n" | tail -n +2
        return 0
    else
        echo "ERROR: Certificate not found."
        return 1
    fi
}

# 跨平台使用的 open 命令
if [ ! $(uname -s) = 'Darwin' ]; then
    if grep -q Microsoft /proc/version; then
        # Ubuntu on Windows using the Linux subsystem
        alias open='explorer.exe'
    else
        alias open='xdg-open'
    fi
fi

# 不带任何参数则打开当前目录，否则打开指定目录
function o() {
    if [ $# -eq 0 ]; then
        open .
    else
        open "$@"
    fi
}

# tre 是 tree 命令的优化，忽略了部分目录： brew install tree
function tre() {
    tree -aC -I '.git|node_modules|bower_components|vendor' --dirsfirst "$@" | less -FRNX
}

# chrome 使用 proxy - 推荐使用 SwitchyOmega 插件
function chromep() {
    if [ -z "${1}" ]; then
        echo "ERROR: No socks port specified."
        return 1
    fi
    if lsof -i ":$1" >/dev/null 2>&1; then
        "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
        --user-data-dir="$HOME/.cache/chrome/proxy-profile" \
        --proxy-server="socks5://localhost:$1"
    else
        echo "ERROR: invalid socks port."
        return 1
    fi
}

# 清理缓存使用上面的 clearCache 即可
function yarnHelper() {
    YARN_CACHE_DIR=$(yarn config current | grep cacheFolder | sed "s/\"cacheFolder\": \"\(.*\)\",*/\1/" | xargs)
    YARN_TEMP_DIR=$(yarn config current | grep tempFolder | sed "s/\"tempFolder\": \"\(.*\)\",*/\1/" | xargs)
    case $1 in
    "--show" | "-s")
        du -sh "$YARN_TEMP_DIR"
        du -sh "$YARN_CACHE_DIR"
        ;;
    "--clean" | "-c")
        case $2 in
        "" | "t" | "T")
            if [[ -d "$YARN_TEMP_DIR" ]]; then
                echo -e "Start clean: \e[32m$YARN_TEMP_DIR\e[0m"
                rm -rf "$YARN_TEMP_DIR"
                mkdir "$YARN_TEMP_DIR"
                echo -e "\e[32mDone.\e[0m"
            else
                echo -e "$YARN_TEMP_DIR not exists"
            fi
            ;;
        "c" | "C")
            if [[ -d "$YARN_CACHE_DIR" ]]; then
                echo -e "Start clean: \e[32m$YARN_CACHE_DIR\e[0m"
                rm -rf "$YARN_CACHE_DIR"
                mkdir "$YARN_CACHE_DIR"
                mkdir "$YARN_TEMP_DIR"
                echo -e "\e[32mDone.\e[0m"
            else
                echo -e "$YARN_CACHE_DIR not exists"
            fi
            ;;
        esac
        ;;
    *)
        printf "\n"
        echo -e "\e[32m-s, --show\e[0m           show cache and temp foloder of yarn"
        echo -e "\e[32m-c, --clean [c | t]\e[0m  clean all cache or temp files, c means cache, t means temp, default is temp"
        echo -e "\e[32m-h, --help\e[0m           display help message"
        printf "\n"
        ;;
    esac
}